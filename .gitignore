spot_micro_motion_cmd/libs/spot_micro_kinematics_cpp/build/
spot_micro_motion_cmd/libs/spot_micro_kinematics_cpp/devel/
extensions/packages/spot_micro_motion_cmd/libs/spot_micro_kinematics_cpp/build/
extensions/packages/spot_micro_motion_cmd/libs/spot_micro_kinematics_cpp/devel/
