.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
*.manifest
*.spec

# ============================================================
# Virtual Environments
# ============================================================
.venv/
venv/
ENV/
env/
.env

# ============================================================
# IDE / Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.bak
*.tmp
*.orig

# ============================================================
# ROS Parameters / Calibration Data (machine-specific)
# ============================================================
# These files contain machine-specific calibration values
# and should be managed per-deployment, not committed.
*.yaml.bak
*.yml.bak
config/calibration/
config/secrets/
calibration/
*.calibration
*.param

# ============================================================
# Hardware / Embedded (machine-specific)
# ============================================================
/dev/
/proc/
/sys/
*.hex
*.bin (except 3D models)

# ============================================================
# Documentation build outputs (local only)
# ============================================================
docs/_build/
docs/.doctrees/

# ============================================================
# Temporary / OS-specific
# ============================================================
*.log
*.tmp
*.cache
core
*~

# ============================================================
# Windows-specific
# ============================================================
~$*
Thumbs.db
Desktop.ini

# ============================================================
# OrangePi / ARM Linux specific
# ============================================================
# SSH keys
.ssh/
known_hosts

# GPU / acceleration libraries (device-specific)
*.so.user
*.aarch64

# ROS bag files (can be very large)
*.bag
*.mcap

# ============================================================
# Hardware documentation files
# ============================================================
hardware/~$*.xlsx
hardware/~$*.pdf
hardware/~$*.docx
hardware/~$*.dwg

# ============================================================
# Keep 3D print files but ignore large batch folders
# ============================================================
hardware/3D模型及打印文件/打印全盘文件/
!hardware/3D模型及打印文件/打印全盘文件/*.stl
!hardware/3D模型及打印文件/打印全盘文件/*.step
!hardware/3D模型及打印文件/打印全盘文件/*.3mf

